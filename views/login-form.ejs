<!DOCTYPE html>
<html lang="en">
    <%- include("./partials/head.ejs") %>
<body>
    <% if (currentUser) { %>
        <h1>Welcome Back <%= currentUser.first_name %></h1>
        <a href="/new-message"><button>Create New Message</button></a>
        <a href="/"><button>See Member Messages</button></a>
        <% const nonMember = currentUser.membership_status === false %>
        <% if (nonMember) { %>
            <div>
                <p><b>You are not yet a club member, join the club to have access to countless benefits!</b></p>
                <a href="/join-club"><button>Join Club</button></a>
            </div>
        <% } %>
        <p>Or Simply</p>
        <a href="/log-out"><button>Log Out</button></a>
    <% } else { %>    
        <h1><%= title %></h1>
        <form action="/log-in" method="POST">
            <label for="email">Email Address: </label>
            <input type="email" id="email" name="email" required>
            <label for="password">Password: </label>
            <input type="password" id="password" name="password" required>
            <button type="submit">Log In</button>
        </form>
    <% } %>
</body>
</html>