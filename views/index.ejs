<!DOCTYPE html>
<html lang="en">
    <%- include("./partials/head.ejs") %>
<body>
    <h1>Welcome To Members Only Club</h1>
    <% if (currentUser) { %>
         <% const member = currentUser.membership_status === true %>
        <nav>
            <ul>
                <% if (!member) { %>
                    <li><a href="/join-club">Join Club</a> to get benefits!</li> 
                <% } %>
                <li><a href="/log-out">Log Out</a></li>
            </ul>
        </nav>
    <% } else { %>
        <nav>
            <ul>
                <li><a href="/sign-up">Sign Up</a></li> 
                <li>Already have an account? <a href="/log-in">Log In</a></li>
            </ul>
        </nav>
    <% } %>
    <h2><%= title %></h2>
    <% if (locals.messages) { %>
        <ol>
            <% messages.forEach(message => { %>
                <li>
                    <p><b><%= message.title%></b></p>
                    <% if (currentUser) { %>
                        <% const member = currentUser.membership_status === true %>
                        <% if (member) { %>
                            <p><b>Author: </b><%= message.first_name + " " + message.last_name %></p>
                            <p><b>Created At: </b><%= message.created_at %></p> 
                        <% } %>
                    <% } %>
                    <p><%= message.message_text%></p>
                </li>
            <% }); %>
        </ol>
    <% } %>
</body>
</html>